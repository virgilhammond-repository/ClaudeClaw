name: Content
description: YouTube scripts, LinkedIn posts, carousels, trend research, content calendar

telegram_bot_token_env: CONTENT_BOT_TOKEN

model: claude-sonnet-4-6

# Optional: auto-inject your Obsidian vault into this agent's context.
# Uncomment and point `vault:` at your real vault path. If you don't use
# Obsidian, leave this whole block commented.
# obsidian:
#   vault: /path/to/your/obsidian/vault
#   folders:
#     - YouTube/
#     - Content/
#     - Teaching/
#   read_only:
#     - Daily Notes/
